{
  "name": "lan-pong",
  "version": "1.0.0",
  "description": "Browser-based two-player Ping-Pong for local network play",
  "main": "server/ws-server.js",
  "scripts": {
    "start": "node server/ws-server.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/game.test.js --coverage",
    "test:int": "jest tests/ws-server.test.js",
    "lint": "eslint server/ client/ tests/"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "tests/"
    ],
    "coverageThreshold": {
      "./server/game.js": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    },
    "testTimeout": 10000
  }
}
